@model ConfReserve.Models.Entities.ConferenceRoom

@{
    ViewData["Title"] = "Dodaj Nową Salę";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm border-0 rounded-4 hover-shadow">
                <div class="card-body p-4 p-md-5">
                    <h3 class="fw-bold text-dark mb-2"><i class="bi bi-plus-circle text-info me-2"></i> Nowa sala konferencyjna</h3>
                    <p class="text-muted small mb-4">Wprowadź parametry techniczne i cenowe nowej przestrzeni biurowej.</p>

                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label small fw-bold text-secondary">Nazwa sali</label>
                            <input asp-for="Name" class="form-control rounded-3" placeholder="np. Sala Diamentowa A" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Capacity" class="form-label small fw-bold text-secondary">Pojemność (osoby)</label>
                                <input asp-for="Capacity" type="number" class="form-control rounded-3" placeholder="np. 12" />
                                <span asp-validation-for="Capacity" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="PricePerHour" class="form-label small fw-bold text-secondary">Stawka za godzinę (PLN)</label>
                                <input asp-for="PricePerHour" type="number" step="0.01" class="form-control rounded-3" placeholder="np. 150.00" />
                                <span asp-validation-for="PricePerHour" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label small fw-bold text-secondary">Opis przestrzeni i wyposażenia</label>
                            <textarea asp-for="Description" class="form-control rounded-3" rows="4" placeholder="Opisz salę (np. rzutnik, klimatyzacja, tablica suchościeralna)..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-nordic-primary px-4 fw-bold rounded-3 shadow-sm flex-grow-1">
                                <i class="bi bi-check-circle me-1"></i> Utwórz salę
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-3">Anuluj</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
@model IEnumerable<ConfReserve.Models.Entities.ConferenceRoom>

@{
    ViewData["Title"] = "Zarządzanie Salami";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark mb-0"><i class="bi bi-sliders text-info me-2"></i> Zarządzanie Salami</h2>
        <a asp-action="Create" class="btn btn-nordic-primary fw-bold rounded-3 shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Dodaj nową salę
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-secondary small text-uppercase">
                        <tr>
                            <th class="ps-4">Nazwa Sali</th>
                            <th>Pojemność</th>
                            <th>Cena za godzinę</th>
                            <th class="text-end pe-4">Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-5">
                                    <i class="bi bi-building-x display-6 text-muted mb-2 d-block"></i>
                                    Brak zdefiniowanych sal konferencyjnych w systemie.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 align-middle fw-bold text-dark">@item.Name</td>
                                    <td class="align-middle text-secondary small">
                                        <i class="bi bi-people me-1"></i> @item.Capacity os.
                                    </td>
                                    <td class="align-middle fw-semibold text-dark">@item.PricePerHour.ToString("C")</td>
                                    <td class="text-end pe-4">
                                        <div class="d-inline-flex gap-1">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary px-2 py-1 rounded-2" title="Edytuj">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger px-2 py-1 rounded-2" title="Usuń">
                                                <i class="bi bi-trash3"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
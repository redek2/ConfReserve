<!DOCTYPE html>
<html lang="pl" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ConfReserve</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column h-100">
    <div class="flex-shrink-0">
        <header class="sticky-top shadow-sm">
            <nav class="navbar navbar-expand-md navbar-dark navbar-nordic py-3">
                <div class="container">
                    <a class="navbar-brand fw-bold d-flex align-items-center text-white" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-cpu text-info me-2"></i> ConfReserve
                    </a>
                    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-md-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1 gap-1">
                            <li class="nav-item">
                                <a class="nav-link text-white-50" asp-controller="Home" asp-action="Index">Strona Główna</a>
                            </li>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                if (User.IsInRole("Admin"))
                                {
                                    <li class="nav-item"><a class="nav-link text-info" asp-controller="ConferenceRooms" asp-action="Index">Sale (Admin)</a></li>
                                    <li class="nav-item"><a class="nav-link text-info" asp-controller="AdminReservations" asp-action="Index">Rezerwacje (Admin)</a></li>
                                }
                                if (User.IsInRole("User"))
                                {
                                    <li class="nav-item"><a class="nav-link text-white" asp-controller="ClientRooms" asp-action="Index">Przeglądaj Sale</a></li>
                                    <li class="nav-item"><a class="nav-link text-white" asp-controller="Reservations" asp-action="MyReservations">Moje Rezerwacje</a></li>
                                }
                            }
                        </ul>
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </nav>
        </header>

        <div class="container my-5">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="footer mt-auto py-3 bg-dark text-center text-white-50 border-top border-info">
        <div class="container small">
            &copy; 2026 - ConfReserve - Profesjonalny System Zarządzania Przestrzenią Biurową
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
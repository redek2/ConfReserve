<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ConfReserve</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ConfReserve.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-building-gear text-dark"></i> ConfReserve
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Strona Główna</a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item border-start ps-2 ms-2">
                                    <a class="nav-link text-danger fw-bold" asp-controller="ConferenceRooms" asp-action="Index">
                                        <i class="bi bi-sliders"></i> Sale (Admin)
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-danger fw-bold" asp-controller="AdminReservations" asp-action="Index">
                                        <i class="bi bi-calendar-check"></i> Rezerwacje (Admin)
                                    </a>
                                </li>
                            }
                            @if (User.IsInRole("User"))
                            {
                                <li class="nav-item border-start ps-2 ms-2">
                                    <a class="nav-link text-dark" asp-controller="ClientRooms" asp-action="Index">
                                        <i class="bi bi-search"></i> Przeglądaj Sale
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Reservations" asp-action="MyReservations">
                                        <i class="bi bi-journal-bookmark"></i> Moje Rezerwacje
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted position-absolute bottom-0 w-100 py-3 bg-light">
        <div class="container text-center">
            &copy; 2026 - ConfReserve - Projekt Zaliczeniowy MVC
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
@model IEnumerable<ConfReserve.Models.Entities.Reservation>

@{
    ViewData["Title"] = "Dashboard & Rezerwacje";
}

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-speedometer2"></i> Panel Administratora</h2>

    <div class="row mb-5">
        <div class="col-md-3 mb-3">
            <div class="card bg-primary text-white h-100 shadow-sm">
                <div class="card-body d-flex flex-column justify-content-center text-center">
                    <h6 class="text-uppercase mb-2 text-white-50">Wszystkie rezerwacje</h6>
                    <h2 class="display-6 fw-bold mb-0">@ViewBag.TotalReservations</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-warning text-dark h-100 shadow-sm">
                <div class="card-body d-flex flex-column justify-content-center text-center">
                    <h6 class="text-uppercase mb-2 text-muted">Oczekujące (Pending)</h6>
                    <h2 class="display-6 fw-bold mb-0">@ViewBag.PendingCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-success text-white h-100 shadow-sm">
                <div class="card-body d-flex flex-column justify-content-center text-center">
                    <h6 class="text-uppercase mb-2 text-white-50">Zatwierdzone</h6>
                    <h2 class="display-6 fw-bold mb-0">@ViewBag.ApprovedCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-info text-white h-100 shadow-sm">
                <div class="card-body d-flex flex-column justify-content-center text-center">
                    <h6 class="text-uppercase mb-2 text-white-50">Przewidywany Przychód</h6>
                    <h2 class="display-6 fw-bold mb-0">@ViewBag.TotalRevenue.ToString("C")</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0"><i class="bi bi-list-task"></i> Spływające wnioski o rezerwacje</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Użytkownik</th>
                            <th>Sala</th>
                            <th>Termin od</th>
                            <th>Termin do</th>
                            <th>Status</th>
                            <th class="text-end px-4">Decyzja</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">Brak zarejestrowanych rezerwacji w systemie.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                string statusBadgeClass = item.Status switch
                                {
                                    "Approved" => "bg-success",
                                    "Cancelled" => "bg-danger",
                                    _ => "bg-warning text-dark"
                                };

                                <tr>
                                    <td>
                                        <div class="fw-bold">@item.User?.FirstName @item.User?.LastName</div>
                                        <small class="text-muted">@item.User?.Email</small>
                                    </td>
                                    <td><span class="badge bg-secondary">@item.ConferenceRoom?.Name</span></td>
                                    <td>@item.StartTime.ToString("g")</td>
                                    <td>@item.EndTime.ToString("g")</td>
                                    <td><span class="badge @statusBadgeClass">@item.Status</span></td>
                                    <td class="text-end px-4">
                                        @if (item.Status == "Pending")
                                        {
                                            <div class="d-inline-flex">
                                                <form asp-action="Approve" asp-route-id="@item.Id" method="post" class="me-2">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-success">
                                                        <i class="bi bi-check-lg"></i> Zatwierdź
                                                    </button>
                                                </form>
                                                <form asp-action="Reject" asp-route-id="@item.Id" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-danger">
                                                        <i class="bi bi-x-lg"></i> Odrzuć
                                                    </button>
                                                </form>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">Proces zakończony</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
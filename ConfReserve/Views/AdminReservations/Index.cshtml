@model IEnumerable<ConfReserve.Models.Entities.Reservation>

@{
    ViewData["Title"] = "Dashboard & Rezerwacje";
}

<div class="container mt-4">
    <h2 class="mb-4 text-dark fw-bold"><i class="bi bi-speedometer2 text-info me-2"></i> Panel Administratora</h2>

    <div class="row mb-5">
        <div class="col-md-3 mb-3">
            <div class="card bg-white h-100 shadow-sm border-start border-4 border-muted hover-shadow">
                <div class="card-body py-4">
                    <h6 class="text-uppercase small fw-bold text-muted mb-2">Wszystkie rezerwacje</h6>
                    <h2 class="fw-bold text-dark mb-0">@ViewBag.TotalReservations</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-white h-100 shadow-sm border-start border-4 border-warning hover-shadow">
                <div class="card-body py-4">
                    <h6 class="text-uppercase small fw-bold text-warning mb-2">Oczekujące (Pending)</h6>
                    <h2 class="fw-bold text-dark mb-0">@ViewBag.PendingCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-white h-100 shadow-sm border-start border-4 border-success hover-shadow">
                <div class="card-body py-4">
                    <h6 class="text-uppercase small fw-bold text-success mb-2">Zatwierdzone</h6>
                    <h2 class="fw-bold text-dark mb-0">@ViewBag.ApprovedCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-white h-100 shadow-sm border-start border-4 border-info hover-shadow">
                <div class="card-body py-4">
                    <h6 class="text-uppercase small fw-bold text-info mb-2">Przewidywany Przychód</h6>
                    <h2 class="fw-bold text-dark mb-0">@ViewBag.TotalRevenue.ToString("C")</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
        <div class="card-header bg-white py-3 border-bottom">
            <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-list-task text-info me-2"></i> Spływające wnioski o rezerwacje</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-secondary small text-uppercase">
                        <tr>
                            <th class="ps-4">Użytkownik</th>
                            <th>Sala</th>
                            <th>Termin od</th>
                            <th>Termin do</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Decyzja</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    <i class="bi bi-inbox display-6 text-muted mb-2 d-block"></i>
                                    Brak zarejestrowanych rezerwacji w systemie.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                string statusBadgeClass = item.Status switch
                                {
                                    "Approved" => "bg-success bg-opacity-10 text-success",
                                    "Cancelled" => "bg-danger bg-opacity-10 text-danger",
                                    _ => "bg-warning bg-opacity-10 text-warning"
                                };

                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold text-dark">@item.User?.FirstName @item.User?.LastName</div>
                                        <small class="text-muted" style="font-size: 0.8rem;">@item.User?.Email</small>
                                    </td>
                                    <td><span class="badge bg-secondary bg-opacity-10 text-secondary border px-2 py-1.5">@item.ConferenceRoom?.Name</span></td>
                                    <td class="small text-secondary">@item.StartTime.ToString("g")</td>
                                    <td class="small text-secondary">@item.EndTime.ToString("g")</td>
                                    <td><span class="badge @statusBadgeClass px-2 py-1.5 rounded-2">@item.Status</span></td>
                                    <td class="text-end pe-4">
                                        @if (item.Status == "Pending")
                                        {
                                            <div class="d-inline-flex gap-1">
                                                <form asp-action="Approve" asp-route-id="@item.Id" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-success px-2 py-1 rounded-2">
                                                        <i class="bi bi-check-lg"></i>
                                                    </button>
                                                </form>
                                                <form asp-action="Reject" asp-route-id="@item.Id" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-danger px-2 py-1 rounded-2">
                                                        <i class="bi bi-x-lg"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted small"><i class="bi bi-lock-fill me-1"></i>Zakończone</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
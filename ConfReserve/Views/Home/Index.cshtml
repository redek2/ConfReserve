@{
    ViewData["Title"] = "Strona Główna";
}

<div class="container mt-5">
    <div class="card bg-white border-0 shadow-sm rounded-4 p-4 p-md-5 mb-5 hover-shadow">
        <div class="card-body text-center py-4">
            <div class="d-inline-flex align-items-center justify-content-center p-3 rounded-circle mb-4 bg-info bg-opacity-10 text-info">
                <i class="bi bi-building-gear fs-1"></i>
            </div>
            <h1 class="display-4 fw-bold mb-3 text-dark">ConfReserve</h1>
            <p class="col-md-8 fs-5 mx-auto text-secondary mb-4">
                Nowoczesny system rezerwacji sal konferencyjnych. Zarządzaj przestrzenią biurową, planuj spotkania biznesowe i rezerwuj terminy w kilka sekund.
            </p>

            <div class="d-grid gap-3 d-sm-flex justify-content-sm-center pt-2">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="AdminReservations" asp-action="Index" class="btn btn-danger btn-lg px-4 fw-bold shadow-sm">
                            <i class="bi bi-speedometer2 me-2"></i> Dashboard Admina
                        </a>
                        <a asp-controller="ConferenceRooms" asp-action="Index" class="btn btn-lg btn-outline-dark px-4 shadow-sm">
                            <i class="bi bi-sliders me-2"></i> Zarządzaj Salami
                        </a>
                    }
                    else if (User.IsInRole("User"))
                    {
                        <a asp-controller="ClientRooms" asp-action="Index" class="btn btn-nordic-primary btn-lg px-4 fw-bold shadow-sm">
                            <i class="bi bi-search me-2"></i> Przeglądaj Sale
                        </a>
                        <a asp-controller="Reservations" asp-action="MyReservations" class="btn btn-lg btn-outline-dark px-4 shadow-sm">
                            <i class="bi bi-journal-bookmark me-2"></i> Twoje Rezerwacje
                        </a>
                    }
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-nordic-dark btn-lg px-4 fw-bold shadow-sm">
                        <i class="bi bi-box-arrow-in-right me-2"></i> Zaloguj się do systemu
                    </a>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-lg btn-outline-dark px-4 shadow-sm">
                        Utwórz darmowe konto
                    </a>
                }
            </div>
        </div>
    </div>

    <div class="row g-4 py-2 row-cols-1 row-cols-lg-3">
        <div class="col">
            <div class="card h-100 bg-white border-0 shadow-sm p-4 rounded-4 hover-shadow text-center">
                <div class="card-body">
                    <div class="d-inline-flex align-items-center justify-content-center p-3 rounded-3 mb-3 bg-info bg-opacity-10 text-info">
                        <i class="bi bi-shield-check fs-3"></i>
                    </div>
                    <h5 class="fw-bold mb-2 text-dark">Szybka Walidacja</h5>
                    <p class="text-muted small mb-0 px-2">System automatycznie weryfikuje dostępność sali za pomocą technologii AJAX, zapobiegając nakładaniu się rezerwacji w czasie rzeczywistym.</p>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 bg-white border-0 shadow-sm p-4 rounded-4 hover-shadow text-center">
                <div class="card-body">
                    <div class="d-inline-flex align-items-center justify-content-center p-3 rounded-3 mb-3 bg-info bg-opacity-10 text-info">
                        <i class="bi bi-calendar-event fs-3"></i>
                    </div>
                    <h5 class="fw-bold mb-2 text-dark">Pełna Kontrola</h5>
                    <p class="text-muted small mb-0 px-2">Użytkownicy mogą w każdej chwili przeglądać historię swoich rezerwacji oraz anulować wnioski, które nie zostały jeszcze zrealizowane.</p>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 bg-white border-0 shadow-sm p-4 rounded-4 hover-shadow text-center">
                <div class="card-body">
                    <div class="d-inline-flex align-items-center justify-content-center p-3 rounded-3 mb-3 bg-danger bg-opacity-10 text-danger">
                        <i class="bi bi-person-gear fs-3"></i>
                    </div>
                    <h5 class="fw-bold mb-2 text-dark">Panel Nadzorczy</h5>
                    <p class="text-muted small mb-0 px-2">Dedykowany moduł administratora umożliwia elastyczne zarządzanie bazą sal, modyfikację cenników oraz akceptację lub odrzucanie rezerwacji.</p>
                </div>
            </div>
        </div>
    </div>
</div>
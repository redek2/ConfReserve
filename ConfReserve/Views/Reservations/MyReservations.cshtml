@model IEnumerable<ConfReserve.Models.Entities.Reservation>

@{
    ViewData["Title"] = "Moje Rezerwacje";
}

<div class="container mt-4">
    <h2 class="mb-4 text-dark fw-bold"><i class="bi bi-bookmark-star text-info me-2"></i> Twoje rezerwacje sal</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3 mb-3" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm rounded-3 mb-3" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0 rounded-3 overflow-hidden mt-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-secondary small text-uppercase">
                        <tr>
                            <th class="ps-4">Nazwa Sali</th>
                            <th>Rozpoczęcie</th>
                            <th>Zakończenie</th>
                            <th>Cena Łączna</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Akcja</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    <i class="bi bi-journal-x display-6 d-block mb-2 text-muted"></i>
                                    Nie dokonałeś jeszcze żadnych rezerwacji.
                                    <a asp-controller="ClientRooms" asp-action="Index" class="text-info text-decoration-none fw-bold ms-1">Przejrzyj dostępne sale</a>.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                string statusBadgeClass = item.Status switch
                                {
                                    "Approved" => "bg-success bg-opacity-10 text-success",
                                    "Cancelled" => "bg-danger bg-opacity-10 text-danger",
                                    _ => "bg-warning bg-opacity-10 text-warning"
                                };

                                double durationHours = Math.Ceiling((item.EndTime - item.StartTime).TotalHours);
                                decimal totalPrice = (decimal)durationHours * (item.ConferenceRoom?.PricePerHour ?? 0);

                                <tr>
                                    <td class="ps-4 fw-bold text-dark align-middle">@item.ConferenceRoom?.Name</td>
                                    <td class="small text-secondary align-middle">@item.StartTime.ToString("g")</td>
                                    <td class="small text-secondary align-middle">@item.EndTime.ToString("g")</td>
                                    <td class="align-middle text-dark fw-semibold">
                                        @totalPrice.ToString("C")
                                        <small class="text-muted d-block fw-normal" style="font-size: 0.78rem;">(@durationHours.ToString("0.#") h)</small>
                                    </td>
                                    <td class="align-middle"><span class="badge @statusBadgeClass px-2 py-1.5 rounded-2">@item.Status</span></td>
                                    <td class="text-end pe-4 align-middle">
                                        @if (item.Status == "Pending" || item.Status == "Approved")
                                        {
                                            <form asp-controller="Reservations" asp-action="Cancel" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Czy na pewno chcesz anulować tę rezerwację?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-3 px-3">
                                                    <i class="bi bi-calendar-x me-1"></i> Anuluj
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">Brak akcji</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
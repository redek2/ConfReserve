@model IEnumerable<ConfReserve.Models.Entities.Reservation>

@{
    ViewData["Title"] = "Moje Rezerwacje";
}

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-journal-bookmark"></i> Twoje rezerwacje sal konferencyjnych</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm mt-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Nazwa Sali</th>
                            <th>Rozpoczęcie</th>
                            <th>Zakończenie</th>
                            <th>Cena Łączna</th>
                            <th>Status</th>
                            <th class="text-end px-4">Akcja</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    Nie dokonałeś jeszcze żadnych rezerwacji.
                                    <a asp-controller="ClientRooms" asp-action="Index" class="text-decoration-none fw-bold">Przejrzyj dostępne sale</a>.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                string statusBadgeClass = item.Status switch
                                {
                                    "Approved" => "bg-success",
                                    "Cancelled" => "bg-danger",
                                    _ => "bg-warning text-dark"
                                };

                                double durationHours = (item.EndTime - item.StartTime).TotalHours;
                                decimal totalPrice = (decimal)durationHours * (item.ConferenceRoom?.PricePerHour ?? 0);

                                <tr>
                                    <td class="fw-bold text-dark">@item.ConferenceRoom?.Name</td>
                                    <td>@item.StartTime.ToString("g")</td>
                                    <td>@item.EndTime.ToString("g")</td>
                                    <td>@totalPrice.ToString("C") <small class="text-muted">(@durationHours.ToString("0.#") h)</small></td>
                                    <td><span class="badge @statusBadgeClass">@item.Status</span></td>
                                    <td class="text-end px-4">
                                        @if (item.Status == "Pending" || item.Status == "Approved")
                                        {
                                            <form asp-controller="Reservations" asp-action="Cancel" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Czy na pewno chcesz anulować tę rezerwację?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-calendar-x"></i> Anuluj
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">Brak akcji</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
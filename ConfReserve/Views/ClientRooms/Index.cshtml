@model IEnumerable<ConfReserve.Models.Entities.ConferenceRoom>

@{
    ViewData["Title"] = "Dostępne Sale Konferencyjne";
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h2 class="fw-bold">Wybierz salę konferencyjną</h2>
        <p class="text-muted">Przejrzyj nasze profesjonalne przestrzenie i zarezerwuj termin dopasowany do Twoich potrzeb.</p>
    </div>

    <div class="row">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <div class="alert alert-info bg-light border-0 shadow-sm p-4">
                    <i class="bi bi-info-circle display-4 text-secondary mb-3"></i>
                    <h5>Brak dostępnych sal</h5>
                    <p class="text-muted mb-0">Administrator nie dodał jeszcze żadnych sal do systemu.</p>
                </div>
            </div>
        }
        else
        {
            @foreach (var room in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden hover-shadow transition">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title fw-bold mb-0 text-dark">@room.Name</h5>
                                <span class="badge bg-dark">@room.PricePerHour.ToString("0") PLN / h</span>
                            </div>
                            
                            <p class="card-text text-muted flex-grow-1 small mt-2">
                                @(room.Description.Length > 120 ? room.Description.Substring(0, 117) + "..." : room.Description)
                            </p>
                            
                            <hr class="text-muted opacity-25My">
                            
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="text-secondary small">
                                    <i class="bi bi-people-fill me-1"></i> Pojemność: <strong>@room.Capacity os.</strong>
                                </span>
                            </div>
                            
                            <a asp-action="Details" asp-route-id="@room.Id" class="btn btn-outline-dark w-100 fw-bold">
                                <i class="bi bi-calendar-plus me-1"></i> Sprawdź i Zarezerwuj
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div></div>